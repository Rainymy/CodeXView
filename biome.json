{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "vcs": {
    "enabled": false,
    "clientKind": "git",
    "useIgnoreFile": false
  },
  "files": {
    "ignoreUnknown": false,
    "ignore": []
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "tab"
  },
  "organizeImports": {
    "enabled": true
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    },
    "ignore": [
      ".vscode-test/",
      "dist/",
      "output/"
    ]
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double"
    }
  },
  "overrides": [
    {
      "linter": {
        "rules": {
          "correctness": {
            "noConstAssign": "warn",
            "noInvalidConstructorSuper": "warn",
            "noUndeclaredVariables": "warn",
            "noUnreachable": "warn",
            "noUnreachableSuper": "warn",
            "noUnusedVariables": "warn"
          },
          "suspicious": {
            "useValidTypeof": "warn"
          }
        }
      }
    }
  ]
}