{
  "name": "codexview",
  "displayName": "CodeXView",
  "description": "Tool for visualizing code interactions and architecture.",
  "version": "0.0.1",
  "private": true,
  "engines": {
    "vscode": "^1.97.0"
  },
  "categories": [
    "Visualization",
    "AI",
    "Education",
    "Other"
  ],
  "icon": "./assets/icon_128x128.png",
  "galleryBanner": {
    "color": "#1F6790"
  },
  "activationEvents": [],
  "main": "extension.js",
  "contributes": {
    "commands": [
      {
        "command": "codexview.file",
        "title": "CodeXView: File Analysis"
      },
      {
        "command": "codexview.codebase",
        "title": "CodeXView: Workspace Analysis"
      },
      {
        "command": "codexview.webview",
        "title": "CodeXView: Create Webview Test"
      },
      {
        "command": "codexview.newdiagramtest",
        "title": "CodeXView: Test New Diagram"
      }
    ],
    "configuration": [
      {
        "title": "CodeXView",
        "properties": {
          "codexview.saveFolder": {
            "type": "string",
            "default": "CodeXView",
            "description": "Relative path from workspace root where output files will be saved. The folder will be created if it doesn't exist."
          },
          "codexview.canCreateFolder": {
            "type": "boolean",
            "default": true,
            "description": "Whether CodeXView should automatically create the save folder if it doesn't exist."
          },
          "codexview.canCreateFile": {
            "type": "boolean",
            "default": true,
            "description": "Whether CodeXView should create output files inside the save folder."
          },
          "codexview.loadIgnoreRulesFromWorkspace": {
            "type": "boolean",
            "default": true,
            "description": "If true, CodeXView will load ignore rules from the workspace root (e.g. .gitignore)."
          }
        }
      }
    ]
  },
  "scripts": {
    "lint": "eslint .",
    "test": "vscode-test",
    "vscode:prepublish": "npm run lint && npm run build:pro",
    "watch:esbuild": "node esbuild.js --watch",
    "package": "vsce package",
    "build": "node esbuild.js",
    "build:pro": "node esbuild.js --production"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Axmus30/CodeXView.git"
  },
  "bugs": {
    "url": "https://github.com/Axmus30/CodeXView/issues"
  },
  "license": "UNLICENSED",
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@types/mocha": "^10.0.10",
    "@types/node": "20.x",
    "@types/vscode": "^1.97.0",
    "@types/vscode-webview": "^1.57.5",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.4.1",
    "esbuild": "^0.25.1"
  },
  "dependencies": {
    "@azure/identity": "^4.7.0",
    "@azure/keyvault-secrets": "^4.9.0",
    "@azure/openai": "^2.0.0",
    "comment-json": "^4.2.5",
    "fast-glob": "^3.3.3",
    "ignore": "^7.0.3",
    "jointjs": "^3.7.7",
    "oniguruma-to-es": "^4.1.0",
    "path-right-join": "^1.0.0",
    "picocolors": "^1.1.1",
    "viz.js": "^2.1.2",
    "web-tree-sitter": "^0.25.3",
    "yaml": "^2.7.0"
  }
}